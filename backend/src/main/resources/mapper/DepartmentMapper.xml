<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.ams.mapper.DepartmentMapper">

    <resultMap id="departmentResultMap" type="com.company.ams.entity.Department">
        <id property="deptId" column="dept_id"/>
        <result property="deptName" column="dept_name"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="departmentResultMap">
        SELECT dept_id, dept_name, created_at
        FROM tb_department
        ORDER BY dept_id
    </select>

    <select id="findById" resultMap="departmentResultMap">
        SELECT dept_id, dept_name, created_at
        FROM tb_department
        WHERE dept_id = #{deptId}
    </select>

    <insert id="insert" parameterType="com.company.ams.entity.Department" useGeneratedKeys="true" keyProperty="deptId">
        INSERT INTO tb_department (dept_name)
        VALUES (#{deptName})
    </insert>

    <update id="update" parameterType="com.company.ams.entity.Department">
        UPDATE tb_department
        SET dept_name = #{deptName}
        WHERE dept_id = #{deptId}
    </update>

    <delete id="deleteById">
        DELETE FROM tb_department WHERE dept_id = #{deptId}
    </delete>

    <select id="countUsersByDeptId" resultType="int">
        SELECT COUNT(*) FROM tb_user WHERE dept_id = #{deptId}
    </select>

</mapper>
