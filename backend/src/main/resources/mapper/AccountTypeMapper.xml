<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.ams.mapper.AccountTypeMapper">

    <resultMap id="accountTypeResultMap" type="com.company.ams.entity.AccountType">
        <id property="typeId" column="type_id"/>
        <result property="typeName" column="type_name"/>
        <result property="description" column="description"/>
        <result property="accountCount" column="account_count"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="selectColumns">
        SELECT t.type_id, t.type_name, t.description, t.created_at,
               (SELECT COUNT(*) FROM tb_password p WHERE p.type_id = t.type_id) AS account_count
        FROM tb_account_type t
    </sql>

    <select id="findAll" resultMap="accountTypeResultMap">
        <include refid="selectColumns"/>
        ORDER BY t.type_id
    </select>

    <select id="findById" resultMap="accountTypeResultMap">
        <include refid="selectColumns"/>
        WHERE t.type_id = #{typeId}
    </select>

    <insert id="insert" parameterType="com.company.ams.entity.AccountType" useGeneratedKeys="true" keyProperty="typeId">
        INSERT INTO tb_account_type (type_name, description)
        VALUES (#{typeName}, #{description})
    </insert>

    <update id="update" parameterType="com.company.ams.entity.AccountType">
        UPDATE tb_account_type
        SET type_name = #{typeName}, description = #{description}
        WHERE type_id = #{typeId}
    </update>

    <delete id="deleteById">
        DELETE FROM tb_account_type WHERE type_id = #{typeId}
    </delete>

</mapper>
